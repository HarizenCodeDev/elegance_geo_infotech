// Datasource and generator
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  passwordHash        String
  role                String    @default("developer")
  employeeId          String?   @unique
  department          String?
  dob                 DateTime?
  gender              String?
  maritalStatus       String?
  salary              Float?
  profileImage        String?
  firstLogin          Boolean   @default(true)
  forcePasswordChange Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  lastSeen            DateTime?

  leaves           Leave[]
  attendance       Attendance[]
  announcements    Announcement[]    @relation("AnnouncementCreator")
  chatMessages     ChatMessage[]     @relation("AuthorMessages")
  notifications    Notification[]
  payroll          Payroll[]
  auditLogs        AuditLog[]
  passwordRequests PasswordRequest[]
  receivedReviews  Review[]          @relation("RevieweeReviews")
  givenReviews     Review[]          @relation("ReviewerReviews")
}

model Leave {
  id                 String      @id @default(cuid())
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId             String
  type               String
  from               DateTime?
  to                 DateTime?
  description        String?
  status             LeaveStatus @default(Pending)
  level1_approved_by String?
  level1_approved_at DateTime?
  level2_approved_by String?
  level2_approved_at DateTime?
  createdAt          DateTime    @default(now())

  @@index([userId])
}

enum LeaveStatus {
  Pending
  Level1Approved
  Level1Rejected
  Level2Approved
  Level2Rejected
}

model Attendance {
  id         String    @id @default(cuid())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  date       DateTime
  status     String
  checkInAt  DateTime?
  checkOutAt DateTime?
  createdAt  DateTime  @default(now())

  @@unique([userId, date])
}

model Announcement {
  id                  String   @id @default(cuid())
  createdBy           User     @relation("AnnouncementCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdById         String
  title               String
  message             String
  audienceRoles       String[]
  audienceDepartments String[]
  createdAt           DateTime @default(now())
}

model ChatMessage {
  id        String   @id @default(cuid())
  type      String // "direct" | "group"
  contactId String // userId for direct (other party) or group id string
  text      String
  from      User     @relation("AuthorMessages", fields: [fromId], references: [id], onDelete: Cascade)
  fromId    String
  toUserId  String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String // "leave_approved", "new_announcement", "payroll_ready"
  read      Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

model PasswordRequest {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  userId    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([email])
  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValues Json?
  newValues Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model Payroll {
  id         String   @id @default(cuid())
  employeeId String
  month      String // "2024-01"
  baseSalary Float
  deductions Float    @default(0)
  netPay     Float
  pdfPath    String?
  employee   User     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([employeeId, month])
}

model Review {
  id         String   @id @default(cuid())
  revieweeId String
  reviewerId String
  rating     Int      @default(3)
  feedback   String?
  reviewDate DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  reviewee User @relation("RevieweeReviews", fields: [revieweeId], references: [id], onDelete: Cascade)
  reviewer User @relation("ReviewerReviews", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([revieweeId])
  @@index([reviewerId])
}
