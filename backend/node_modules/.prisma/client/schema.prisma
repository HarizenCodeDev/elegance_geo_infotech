// Datasource and generator
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String
  role          String    @default("developer")
  employeeId    String?   @unique
  department    String?
  dob           DateTime?
  gender        String?
  maritalStatus String?
  salary        Float?
  profileImage  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  leaves        Leave[]
  attendance    Attendance[]
  announcements Announcement[] @relation("AnnouncementCreator")
  chatMessages  ChatMessage[]  @relation("AuthorMessages")
}

model Leave {
  id          String    @id @default(cuid())
  user        User      @relation(fields: [userId], references: [id])
  userId      String
  type        String
  from        DateTime?
  to          DateTime?
  description String?
  status      String    @default("Pending")
  createdAt   DateTime  @default(now())
}

model Attendance {
  id         String    @id @default(cuid())
  user       User      @relation(fields: [userId], references: [id])
  userId     String
  date       DateTime
  status     String
  checkInAt  DateTime?
  checkOutAt DateTime?
  createdAt  DateTime  @default(now())

  @@unique([userId, date])
}

model Announcement {
  id                  String   @id @default(cuid())
  createdBy           User     @relation("AnnouncementCreator", fields: [createdById], references: [id])
  createdById         String
  title               String
  message             String
  audienceRoles       String[]
  audienceDepartments String[]
  createdAt           DateTime @default(now())
}

model ChatMessage {
  id        String   @id @default(cuid())
  type      String // "direct" | "group"
  contactId String // userId for direct (other party) or group id string
  text      String
  from      User     @relation("AuthorMessages", fields: [fromId], references: [id])
  fromId    String
  toUserId  String?
  createdAt DateTime @default(now())
}
